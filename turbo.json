{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "env": ["VITE_*"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../../scripts/build-registry.ts",
        "../../packages/ui/src/**"
      ],
      "outputs": [
        "dist/**",
        ".output/**",
        ".vercel/**",
        "build/**",
        "public/r/**"
      ]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    }
  }
}
